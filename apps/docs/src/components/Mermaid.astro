---
type Props = {
  chart: string;
};

// biome-ignore lint/correctness/noUnusedVariables: Astro renders chart in the template.
const { chart } = Astro.props;
---

<div class="mermaid">{chart}</div>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    securityLevel: "strict",
    startOnLoad: true,
    theme: "neutral"
  });
</script>
